{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "dockerfile"
  },
  "deploy": {
    "startCommand": "/app/start.sh",
    "restartPolicyMaxRetries": 5,
    "restartPolicyWindowMs": 120000,
    "healthchecks": {
      "liveness": {
        "initialDelaySeconds": 10,
        "periodSeconds": 30
      }
    }
  }
}
